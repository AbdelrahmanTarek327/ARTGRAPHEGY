# Server port (API)
SERVER_PORT=3001

# Secret key for admin-only access to inquiry exports.
# Use a long random string (at least 16 characters).
# Example: openssl rand -hex 32
ADMIN_API_KEY=replace-with-your-secret-key-here

# Set to production when running npm start
NODE_ENV=development

# ── Google Sheets (required for Netlify deployment) ──
# Spreadsheet ID from the Google Sheet URL:
# https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Service-account credentials (from the JSON key file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
