# Server port (API)
SERVER_PORT=3001

# Secret key for admin-only access to inquiry exports.
# Use a long random string (at least 16 characters).
# Example: openssl rand -hex 32
ADMIN_API_KEY=replace-with-your-secret-key-here

# Set to production when running npm start
NODE_ENV=development

# ── Email SMTP Server (required for Netlify inquiries endpoint) ──
# SMTP server hostname (e.g. smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587
# SMTP username / sending email address
SMTP_USER=
# SMTP password / App Password
SMTP_PASS=
# Recipient email address where inquiries will be sent (default: bodytarek2003@gmail.com)
NOTIFICATION_EMAIL=bodytarek2003@gmail.com
