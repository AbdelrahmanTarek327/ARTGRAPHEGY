    "express-rate-limit": "^7.5.0",
    "framer-motion": "^11.15.0",
    "helmet": "^8.0.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.469.0",
    "next-themes": "^0.4.6",
    "dotenv": "^16.4.7",
    "react": "^19.0.0",
    "react-day-picker": "^9.11.1",
