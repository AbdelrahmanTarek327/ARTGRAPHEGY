{
  "name": "artgraphegy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite --config vite.config.ts --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && vite build --config vite.config.ts && tsc -p server/tsconfig.json",
    "start": "cross-env NODE_ENV=production node server/dist/index.js",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
